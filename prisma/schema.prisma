datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id               Int       @id @default(autoincrement())
  email            String    @unique
  fullName         String
  field            String
  bio              String?
  avatarUrl        String?
  avatarType       String    @default("procedural")
  avatarFilter     String    @default("none")
  createdAt        DateTime  @default(now())
  role             String    @default("user") // "user" | "creator"
  creatorStatus    String    @default("none") // "none" | "pending" | "rejected" | "approved"
  auditionCount    Int       @default(0)
  auditionAudioUrl String?
  auditionFeedback String?
  auditionScore    Int       @default(0)
  phone            String?   @unique
  episodes         Episode[]
  seasons          Season[]
}

model Season {
  id          Int       @id @default(autoincrement())
  seasonNum   String
  titleFa     String
  titleEn     String
  isCompleted Boolean   @default(false)
  createdAt   DateTime  @default(now())
  userId      Int
  user        User      @relation(fields: [userId], references: [id])
  episodes    Episode[]

  @@unique([userId, seasonNum])
}

model Episode {
  id               Int      @id @default(autoincrement())
  titleFa          String
  titleEn          String
  descFa           String
  descEn           String
  audioUrl         String
  coverUrl         String
  duration         String
  episodeNum       String
  status           String   @default("draft")
  score            Int      @default(0)
  fwr              Float    @default(0)
  wpm              Float    @default(0)
  lexicalDiversity Float    @default(0)
  rejectionReason  String?
  transcript       String?
  aiAnalysis       String?
  createdAt        DateTime @default(now())
  userId           Int?
  user             User?    @relation(fields: [userId], references: [id])
  seasonId         Int?
  season           Season?  @relation(fields: [seasonId], references: [id])
  reports          Report[]

  @@unique([seasonId, episodeNum])
}

model Report {
  id        Int      @id @default(autoincrement())
  ipAddress String
  reason    String
  createdAt DateTime @default(now())
  episodeId Int
  episode   Episode  @relation(fields: [episodeId], references: [id])

  @@unique([ipAddress, episodeId])
}

model AiHistory {
  id               Int      @id @default(autoincrement())
  fileName         String
  audioUrl         String?
  transcription    String
  analysis         String?
  summaryFa        String?
  summaryEn        String?
  linkedinPost     String?
  githubSummary    String?
  chapters         String?
  fwr              Float?
  wpm              Float?
  wpmStatus        String?
  lexicalDiversity Float?
  createdAt        DateTime @default(now())
}
